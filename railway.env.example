# ============================================================
# Railway Backend Environment Variables
# ============================================================
# Copy this file to .env.railway and fill in the values,
# then add them to Railway Dashboard > Variables
# ============================================================

# --- Database (Neon Postgres) ---
DATABASE_TYPE=postgresql
DATABASE_HOST=your-neon-host.neon.tech
DATABASE_PORT=5432
DATABASE_USER=your-neon-username
DATABASE_PASSWORD=your-neon-password
DATABASE_NAME=openwebui

# --- Security ---
# Generate with: node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
WEBUI_SECRET_KEY=change-me-to-a-random-64-char-hex-string

# --- API Keys ---
OPENAI_API_KEY=sk-your-openai-key
OLLAMA_BASE_URL=

# --- App Config ---
ENV=prod
PORT=8080
WEBUI_AUTH=true
ENABLE_INITIAL_ADMIN_SIGNUP=true
WEBUI_ADMIN_EMAIL=admin@example.com
WEBUI_ADMIN_PASSWORD=ChangeMe123!
WEBUI_ADMIN_NAME=Admin

# --- CORS ---
# IMPORTANT: Update with your actual Vercel frontend URL
CORS_ALLOW_ORIGIN=https://open-webui-blue-gamma.vercel.app
FORWARDED_ALLOW_IPS=*

# --- Performance ---
USE_SLIM=true

# --- Analytics Off ---
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false
ENABLE_VERSION_UPDATE_CHECK=false
